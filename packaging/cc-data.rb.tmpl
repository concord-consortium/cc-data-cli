class CcData < Formula
  desc "Download and query Concord Consortium researcher data with SQL"
  homepage "https://github.com/concord-consortium/cc-data-cli"
  version "__VERSION__"

  on_macos do
    on_arm do
      url "https://github.com/concord-consortium/cc-data-cli/releases/download/v__VERSION__/cc-data___VERSION___darwin_arm64.tar.gz"
      sha256 "__SHA_DARWIN_ARM64__"
    end
    on_intel do
      url "https://github.com/concord-consortium/cc-data-cli/releases/download/v__VERSION__/cc-data___VERSION___darwin_amd64.tar.gz"
      sha256 "__SHA_DARWIN_AMD64__"
    end
  end

  on_linux do
    on_intel do
      url "https://github.com/concord-consortium/cc-data-cli/releases/download/v__VERSION__/cc-data___VERSION___linux_amd64.tar.gz"
      sha256 "__SHA_LINUX_AMD64__"
    end
  end

  def install
    bin.install "cc-data"
  end

  test do
    assert_match version.to_s, shell_output("#{bin}/cc-data version")
  end
end
